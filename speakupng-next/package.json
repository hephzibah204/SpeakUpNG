{
  "name": "speakupng-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:seed": "node scripts/seed-postgres.js",
    "enrich:profiles": "tsx scripts/enrich-all-profiles.ts",
    "enrich:profiles:force": "tsx scripts/enrich-all-profiles.ts --force",
    "db:news": "node scripts/add-news-tables.js",
    "db:ratings": "node scripts/add-politician-ratings.js",
    "db:migrate": "node scripts/add-missing-tables.js",
    "db:civic": "node scripts/add-civic-features-tables.js",
    "db:elections": "node scripts/seed-historical-elections.js",
    "db:candidates": "node scripts/seed-2027-candidates.js",
    "db:governors": "node scripts/seed-2027-governorship.js",
    "db:setup": "node scripts/seed-postgres.js && node scripts/add-news-tables.js && node scripts/add-politician-ratings.js && node scripts/add-missing-tables.js",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.2",
    "@ai-sdk/openai": "^4.0.3",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/postgres": "^0.10.0",
    "ai": "^7.0.5",
    "clsx": "^2.0.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.2",
    "dotenv": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.0.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
